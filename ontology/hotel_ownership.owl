<?xml version="1.0"?>
<!DOCTYPE rdf:RDF [
  <!ENTITY owl "http://www.w3.org/2002/07/owl#" >
  <!ENTITY xsd "http://www.w3.org/2001/XMLSchema#" >
  <!ENTITY rdfs "http://www.w3.org/2000/01/rdf-schema#" >
  <!ENTITY rdf "http://www.w3.org/1999/02/22-rdf-syntax-ns#" >
  <!ENTITY vhk "http://example.org/vienna-hotel-kg/" >
]>

<rdf:RDF xmlns="http://example.org/vienna-hotel-kg/"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:schema="http://schema.org/"
     xml:base="http://example.org/vienna-hotel-kg/">

  <!-- Ontology declaration -->
  <owl:Ontology rdf:about="http://example.org/vienna-hotel-kg/ontology">
    <rdfs:label>Vienna Hotel Ownership Knowledge Graph Ontology</rdfs:label>
    <rdfs:comment>
      OWL ontology for representing hotel/accommodation ownership and operation
      relationships in Vienna, Austria. Covers properties listed on booking.com
      and Airbnb, their operators, owning companies, and hotel chains.
    </rdfs:comment>
    <owl:versionInfo>1.0</owl:versionInfo>
  </owl:Ontology>

  <!-- ============================================================
       CLASSES
       ============================================================ -->

  <owl:Class rdf:about="&vhk;Property">
    <rdfs:label>Property</rdfs:label>
    <rdfs:comment>A hotel, apartment, hostel, or other accommodation listing.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://schema.org/LodgingBusiness"/>
  </owl:Class>

  <owl:Class rdf:about="&vhk;Operator">
    <rdfs:label>Operator</rdfs:label>
    <rdfs:comment>
      The individual or company who manages and lists the accommodation
      on a booking platform. May or may not be the legal property owner.
    </rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://schema.org/Organization"/>
  </owl:Class>

  <owl:Class rdf:about="&vhk;OwnerCompany">
    <rdfs:label>Owner Company</rdfs:label>
    <rdfs:comment>
      The legal entity owning the property or operating company.
      Ideally linked to an Austrian Firmenbuch entry.
    </rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://schema.org/Organization"/>
  </owl:Class>

  <owl:Class rdf:about="&vhk;HotelChain">
    <rdfs:label>Hotel Chain</rdfs:label>
    <rdfs:comment>
      A hotel brand or group (e.g. Marriott, AccorHotels, Vienna House).
      Operators may be subsidiaries of a chain.
    </rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://schema.org/Organization"/>
  </owl:Class>

  <owl:Class rdf:about="&vhk;District">
    <rdfs:label>District</rdfs:label>
    <rdfs:comment>A Vienna administrative district (Bezirk), 1st through 23rd.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://schema.org/AdministrativeArea"/>
  </owl:Class>

  <owl:Class rdf:about="&vhk;Platform">
    <rdfs:label>Platform</rdfs:label>
    <rdfs:comment>An online accommodation booking platform (e.g. booking.com, Airbnb).</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="&vhk;FirmenbuchEntry">
    <rdfs:label>Firmenbuch Entry</rdfs:label>
    <rdfs:comment>
      An entry in the Austrian company registry (Firmenbuch), identified by
      a Firmenbuchnummer (FN number).
    </rdfs:comment>
  </owl:Class>

  <!-- ============================================================
       OBJECT PROPERTIES
       ============================================================ -->

  <owl:ObjectProperty rdf:about="&vhk;listedOn">
    <rdfs:label>listed on</rdfs:label>
    <rdfs:comment>A property is listed on a booking platform.</rdfs:comment>
    <rdfs:domain rdf:resource="&vhk;Property"/>
    <rdfs:range rdf:resource="&vhk;Platform"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="&vhk;operatedBy">
    <rdfs:label>operated by</rdfs:label>
    <rdfs:comment>A property is operated/managed by an operator.</rdfs:comment>
    <rdfs:domain rdf:resource="&vhk;Property"/>
    <rdfs:range rdf:resource="&vhk;Operator"/>
    <owl:inverseOf rdf:resource="&vhk;operates"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="&vhk;operates">
    <rdfs:label>operates</rdfs:label>
    <rdfs:domain rdf:resource="&vhk;Operator"/>
    <rdfs:range rdf:resource="&vhk;Property"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="&vhk;subsidiaryOf">
    <rdfs:label>subsidiary of</rdfs:label>
    <rdfs:comment>An operator is a subsidiary or franchisee of a hotel chain.</rdfs:comment>
    <rdfs:domain rdf:resource="&vhk;Operator"/>
    <rdfs:range rdf:resource="&vhk;HotelChain"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="&vhk;owns">
    <rdfs:label>owns</rdfs:label>
    <rdfs:comment>An owner company owns a hotel chain or operating company.</rdfs:comment>
    <rdfs:domain rdf:resource="&vhk;OwnerCompany"/>
    <rdfs:range>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="&vhk;HotelChain"/>
          <rdf:Description rdf:about="&vhk;Operator"/>
          <rdf:Description rdf:about="&vhk;Property"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:range>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="&vhk;locatedIn">
    <rdfs:label>located in</rdfs:label>
    <rdfs:comment>A property is located in a Vienna district.</rdfs:comment>
    <rdfs:domain rdf:resource="&vhk;Property"/>
    <rdfs:range rdf:resource="&vhk;District"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="&vhk;registeredAs">
    <rdfs:label>registered as</rdfs:label>
    <rdfs:comment>An operator or owner company is registered as a Firmenbuch entry.</rdfs:comment>
    <rdfs:domain>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="&vhk;Operator"/>
          <rdf:Description rdf:about="&vhk;OwnerCompany"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="&vhk;FirmenbuchEntry"/>
  </owl:ObjectProperty>

  <!-- ============================================================
       DATATYPE PROPERTIES
       ============================================================ -->

  <owl:DatatypeProperty rdf:about="&vhk;firmenbuchNumber">
    <rdfs:label>Firmenbuch number</rdfs:label>
    <rdfs:comment>Austrian company registry number (FN XXXXXXX a).</rdfs:comment>
    <rdfs:domain rdf:resource="&vhk;FirmenbuchEntry"/>
    <rdfs:range rdf:resource="&xsd;string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="&vhk;legalForm">
    <rdfs:label>legal form</rdfs:label>
    <rdfs:comment>Legal form of the company (GmbH, AG, KG, etc.).</rdfs:comment>
    <rdfs:domain rdf:resource="&vhk;OwnerCompany"/>
    <rdfs:range rdf:resource="&xsd;string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="&vhk;stars">
    <rdfs:label>stars</rdfs:label>
    <rdfs:comment>Hotel star rating (1–5).</rdfs:comment>
    <rdfs:domain rdf:resource="&vhk;Property"/>
    <rdfs:range rdf:resource="&xsd;integer"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="&vhk;propertyType">
    <rdfs:label>property type</rdfs:label>
    <rdfs:comment>Type of accommodation (hotel, hostel, apartment, guest_house, etc.).</rdfs:comment>
    <rdfs:domain rdf:resource="&vhk;Property"/>
    <rdfs:range rdf:resource="&xsd;string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="&vhk;hostListingsCount">
    <rdfs:label>host listings count</rdfs:label>
    <rdfs:comment>Number of listings managed by this operator (from Airbnb data).</rdfs:comment>
    <rdfs:domain rdf:resource="&vhk;Operator"/>
    <rdfs:range rdf:resource="&xsd;integer"/>
  </owl:DatatypeProperty>

</rdf:RDF>
